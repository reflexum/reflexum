{
  "name": "reflexum",
  "version": "0.1.0",
  "description": "Study journal analytics, AI insights, and Telegram digests for Obsidian.",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --external:obsidian --external:electron --external:@codemirror/state --external:@codemirror/view",
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --external:obsidian --external:electron --external:@codemirror/state --external:@codemirror/view --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "obsidian": "^1.10.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "multi-llm-ts": "^4.6.2"
  },
  "keywords": [
    "obsidian",
    "study",
    "analytics",
    "telegram"
  ],
  "license": "MIT"
}
